# Database connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
# Example: postgresql://postgres:password@localhost:5432/repaircafe?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/repaircafe?schema=public"

# App runtime mode: use "prod" to run migrations + seed at container startup, "dev" to skip
APP_ENV="dev"

# Session signing secret (required in production)
SESSION_SECRET="replace-with-long-random-secret"

# Optional: app URL and allowed browser origins for Socket.IO CORS (comma-separated)
APP_URL="https://localhost:3000"
SOCKET_CORS_ORIGINS="https://localhost:3000"
